package pages

import "github.com/stratocraft/stratocraft.dev/internal/views/shared"

templ NotFound() {
	@shared.Base("404") {
		<div class="max-h-screen mx-auto flex flex-col">
			<h1 class="font-mono text-center text-9xl">404</h1>
			<div class="flex flex-col items-center justify-center">
				<p class="font-jbmono text-xl">You seem a bit lost, pardner...</p>
				<a class="mt-8 black-button font-jbmono" href="/" aria-label="Go back to Home">Back to Safety</a>
			</div>
		</div>
	}
}
