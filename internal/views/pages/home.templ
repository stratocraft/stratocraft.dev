package pages

import (
	"github.com/stratocraft/stratocraft.dev/internal/views/shared"
	"github.com/stratocraft/stratocraft.dev/internal/views/lockups"
	"github.com/stratocraft/stratocraft.dev/internal/models"
)

templ Home(posts []*models.Post) {
    @shared.Base("Home") {
        @lockups.Home(posts)
    }
}